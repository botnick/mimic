# macOS
.DS_Store

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# Per-device config (generated by scripts/setup.sh — see mimic.config.example.json)
mimic.config.json
.mimic/

# Local scratch / experiments
.skill-workspace/
.workflow/
tools/_*.exp

# Compiled helper (built on demand from mkvideo.swift)
tools/mkvideo

# Heavy / dead-end artifacts not needed at runtime:
#  - WebDriverAgent never launches on this device (dev services reject the
#    AppSync-sideloaded runner), so the whole WDA tree is dead weight.
#  - go-ios can fetch the DeveloperDiskImage on demand (`ios image auto`),
#    so we don't vendor the DMGs or the old go-ios build.
tools/wda/
tools/goios-old/
tools/goios/ddi/
tools/goios/*.zip
tools/appsync.deb

# Captured traffic / recordings
*.mitm
*.mp4

# Early scaffolding that the live path (server.py -> ios/device.py -> agent.js/tel.js)
# does not use. Kept on disk for reference, left out of the published tree.
mimic/recipes/
mimic/perception/
mimic/drivers/
mimic/actions/
mimic/ios/bridge.py
mimic/ios/touchd/
mimic/ios/av.js
mimic/ios/touch.js
call_state_probe.js
test_core.py

# Unused duplicate gadget (gadget-arm64.dylib is the one the bypass installs)
tools/frida-gadget.dylib
*.pcap
